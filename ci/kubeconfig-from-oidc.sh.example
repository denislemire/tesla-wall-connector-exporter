#!/usr/bin/env bash
# Example: exchange CircleCI OIDC JWT for a Kubernetes bearer token via Authentik.
# Copy to scripts/kubeconfig-from-oidc.sh and wire CircleCI context variables:
#   KUBE_API_SERVER, KUBE_CA_B64, AUTHENTIK_OIDC_TOKEN_URL
# Requires: curl, base64, kubectl (optional verify)
set -euo pipefail

: "${KUBE_API_SERVER:?}"
: "${KUBE_CA_B64:?}"
: "${AUTHENTIK_OIDC_TOKEN_URL:?}"
: "${CIRCLE_OIDC_TOKEN_V2:?}"

TOKEN_JSON="$(curl -sS -X POST "$AUTHENTIK_OIDC_TOKEN_URL" \
  -H "Content-Type: application/x-www-form-urlencoded" \
  --data-urlencode "grant_type=client_credentials" \
  --data-urlencode "client_id=kubernetes-cluster" \
  --data-urlencode "scope=openid profile" \
  --data-urlencode "client_assertion_type=urn:ietf:params:oauth:client-assertion-type:jwt-bearer" \
  --data-urlencode "client_assertion=${CIRCLE_OIDC_TOKEN_V2}")"

ACCESS_TOKEN="$(echo "$TOKEN_JSON" | sed -n 's/.*"access_token":"\([^"]*\)".*/\1/p')"
if [[ -z "$ACCESS_TOKEN" ]]; then
  echo "token exchange failed: $TOKEN_JSON" >&2
  exit 1
fi

mkdir -p "${HOME}/.kube"
CA_FILE="${HOME}/.kube/ca.crt"
echo "$KUBE_CA_B64" | base64 -d > "$CA_FILE"

cat > "${HOME}/.kube/config" <<EOF
apiVersion: v1
kind: Config
clusters:
- cluster:
    certificate-authority: ${CA_FILE}
    server: ${KUBE_API_SERVER}
  name: ci
contexts:
- context:
    cluster: ci
    user: ci
  name: ci
current-context: ci
users:
- name: ci
  user:
    token: ${ACCESS_TOKEN}
EOF

echo "kubeconfig written for ${KUBE_API_SERVER}"
